{
  "version": 1,
  "contract_id": "anti_lie_claim_enforcement",
  "feature_id": "viewer_host_workflow",
  "workflow_type": "workflow_only",
  "plan_path": "docs/notes/anti_lie_claim_enforcement_PHASED_PLAN.md",
  "allowed_mutation_scope": [
    "docs/contracts/anti_lie_claim_enforcement.contract.json",
    "docs/notes/anti_lie_claim_enforcement_PHASED_PLAN.md",
    "tools",
    "tests",
    "artifacts",
    "AGENTS.md",
    "AGENT_WORKING_PROTOCOL.md",
    "docs/PHASED_PLAN_CONTINUITY_PROTOCOL.md",
    ".github/copilot-instructions.md",
    "HANDOFF_LOG.md"
  ],
  "required_operator_inputs": [
    "rebuild the anti-lie stop/task_complete slice from zero trust",
    "keep only machine-state closure blockers in the active hook path",
    "separate bootstrap or orientation outputs from authoritative receipt-evidence paths",
    "record which anti-lie surfaces were kept, narrowed, or demoted",
    "leave the repaired slice clean, receipted, and non-blocking without resuming feature work"
  ],
  "forbidden_operator_prompts": [
    "treat bootstrap or orientation artifacts as authoritative closure proof",
    "block closure on prose-only status rules, capstones, or rhetoric-only audit surfaces",
    "resume product feature work from this repair slice",
    "refresh receipts before the replacement design is stable",
    "treat inherited clean heads as if the current session advanced them"
  ],
  "required_defaults": {
    "workflow_only": "required",
    "authoritative_receipt_evidence_is_stable": "required",
    "closure_blockers_are_machine_state_only": "required",
    "inherited_clean_heads_do_not_require_reproof": "required"
  },
  "forbidden_defaults": {
    "shared_receipt_artifact_paths": "forbidden",
    "prose_only_completion_rules": "forbidden",
    "fresh_session_false_block": "forbidden",
    "product_progress_claim": "forbidden"
  },
  "required_validation_commands": [
    "py -3.14 -m pytest tests/test_viewer_host_checkpoint_guard.py tests/test_viewer_host_contract_proof.py tests/test_agent_workflow_tools.py -q --junitxml artifacts/pytest/anti_lie_workflow_tools.junit.xml",
    "py -3.14 tools/viewer_host_validate_slice_contract.py --contract docs/contracts/anti_lie_claim_enforcement.contract.json --out-json artifacts/validation/anti_lie_claim_enforcement_contract.json",
    "py -3.14 tools/viewer_host_assert_phased_plan_sync.py",
    "py -3.14 tools/viewer_host_validate_hostile_audit.py --plan docs/notes/anti_lie_claim_enforcement_PHASED_PLAN.md --out-json artifacts/validation/anti_lie_claim_enforcement_hostile_audit.json",
    "py -3.14 tools/code_quality_audit.py --check-baseline --out artifacts/code_quality_report.json"
  ],
  "required_acceptance_assertions": [
    {
      "assertion_id": "anti_lie_contract_schema_valid",
      "description": "The replacement anti-lie contract validates successfully",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/anti_lie_claim_enforcement_contract.json",
      "json_path": "checks.contract_schema_valid",
      "equals": true
    },
    {
      "assertion_id": "anti_lie_plan_sync_ok",
      "description": "The replacement anti-lie phased plan stays synchronized",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/viewer_host_assert_phased_plan_sync.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "anti_lie_hostile_audit_ok",
      "description": "The replacement anti-lie slice records a clean hostile re-audit",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/anti_lie_claim_enforcement_hostile_audit.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "anti_lie_stale_authoritative_artifact_still_blocks",
      "description": "Authoritative validation evidence drift still blocks contract-proof closure",
      "evidence_kind": "pytest_junit_case",
      "artifact_path": "artifacts/pytest/anti_lie_workflow_tools.junit.xml",
      "test_nodeid": "tests/test_viewer_host_checkpoint_guard.py::test_evaluate_contract_proof_receipt_guard_revalidates_validation_evidence_artifact_drift"
    },
    {
      "assertion_id": "anti_lie_clean_inherited_head_is_not_reblocked",
      "description": "A clean inherited head without session-local advancement does not false-block stop",
      "evidence_kind": "pytest_junit_case",
      "artifact_path": "artifacts/pytest/anti_lie_workflow_tools.junit.xml",
      "test_nodeid": "tests/test_viewer_host_checkpoint_guard.py::test_build_stop_response_allows_clean_inherited_head_without_contract_proof"
    },
    {
      "assertion_id": "anti_lie_bootstrap_audit_path_is_non_authoritative",
      "description": "Bootstrap audit output stays off the authoritative code-quality artifact path",
      "evidence_kind": "pytest_junit_case",
      "artifact_path": "artifacts/pytest/anti_lie_workflow_tools.junit.xml",
      "test_nodeid": "tests/test_agent_workflow_tools.py::test_bootstrap_audit_writes_to_non_authoritative_path"
    }
  ]
}
