{
  "version": 1,
  "contract_id": "qol_multibrot_exponent",
  "feature_id": "qol_multibrot_exponent_v1",
  "workflow_type": "viewer_first",
  "plan_path": "docs/notes/qol_multibrot_exponent_PHASED_PLAN.md",
  "allowed_mutation_scope": [
    "docs/contracts",
    "docs/notes",
    "ui/fractal_binding_surface_v1.ui_schema.json",
    "ui/fractal_binding_surface_v1.binding_map.md",
    "ui/FractalBindingSurfaceV1.md",
    "ui_app/src",
    "ui_app/tests",
    "tests",
    "HANDOFF_LOG.md"
  ],
  "required_operator_inputs": [
    "real Multibrot exponent hard range is [0.01,32]",
    "real Multibrot exponent UI range is [0.01,12] with logarithmic slider behavior",
    "typed input and automation can set real exponent values through 32",
    "complex exponent is added to the existing multibrot lane",
    "physical mouse automation is forbidden"
  ],
  "forbidden_operator_prompts": [
    "add a new FractalType for complex Multibrot",
    "start resolution UX or FPS pacing work before Branch 1 is closed and merged",
    "use physical mouse automation",
    "silently fall back to a different fractal when complex exponent math is nonfinite",
    "change unrelated fractal defaults or Color Pipeline behavior"
  ],
  "required_defaults": {
    "branch": "codex/qol-multibrot-exponent",
    "target_branch": "master",
    "fractal_type": "multibrot",
    "real_exponent_hard_min": 0.01,
    "real_exponent_hard_max": 32.0,
    "real_exponent_ui_min": 0.01,
    "real_exponent_ui_max": 12.0,
    "imag_exponent_min": -4.0,
    "imag_exponent_max": 4.0,
    "no_physical_mouse_tests": true
  },
  "forbidden_defaults": {
    "new_fractal_type": "forbidden",
    "resolution_pacing_edits": "forbidden_in_branch_1",
    "dynamic_kernel_registration": "forbidden",
    "physical_mouse_tests": "forbidden"
  },
  "required_validation_commands": [
    "py -3.14 tools/code_quality_audit.py --check-baseline --out artifacts/logs/qol_multibrot_exponent_code_quality.json",
    "py -3.14 tools/viewer_host_validate_slice_contract.py --contract docs/contracts/qol_multibrot_exponent.contract.json --out-json artifacts/validation/qol_multibrot_exponent_contract.json",
    "py -3.14 tools/viewer_host_assert_phased_plan_sync.py",
    "py -3.14 tools/viewer_host_validate_hostile_audit.py --plan docs/notes/qol_multibrot_exponent_PHASED_PLAN.md --out-json artifacts/validation/qol_multibrot_exponent_hostile_audit.json",
    "py -3.14 tools/viewer_host_run_logged_command.py --label qol_multibrot_exponent_native_renderer --log artifacts/logs/qol_multibrot_exponent_native_renderer.log -- ui_app/build_tests_vsdevcmd.cmd test_fractal_renderer",
    "py -3.14 tools/viewer_host_run_logged_command.py --label qol_multibrot_exponent_native_final --log artifacts/logs/qol_multibrot_exponent_native_final.log -- ui_app/build_tests_vsdevcmd.cmd",
    "py -3.14 tools/viewer_host_run_logged_command.py --label qol_multibrot_exponent_runtime_publish_final --log artifacts/logs/qol_multibrot_exponent_runtime_publish_final.log -- ui_app/build_vsdevcmd.cmd",
    "py -3.14 -m pytest tests/test_fractal_runtime_multibrot_exponent.py -q --junitxml artifacts/pytest/qol_multibrot_exponent_runtime.junit.xml"
  ],
  "required_acceptance_assertions": [
    {
      "assertion_id": "qol_multibrot_exponent_contract_schema_valid",
      "description": "The Multibrot exponent contract validates successfully",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/qol_multibrot_exponent_contract.json",
      "json_path": "checks.contract_schema_valid",
      "equals": true
    },
    {
      "assertion_id": "qol_multibrot_exponent_plan_sync_ok",
      "description": "The phased plan stays synchronized",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/viewer_host_assert_phased_plan_sync.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "qol_multibrot_exponent_hostile_audit_ok",
      "description": "The hostile audit is complete before closure",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/qol_multibrot_exponent_hostile_audit.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "qol_multibrot_exponent_runtime_no_mouse",
      "description": "Published viewer proof edits below-2, above-12, and imaginary Multibrot exponent controls without physical mouse automation",
      "evidence_kind": "runtime_junit_case",
      "artifact_path": "artifacts/pytest/qol_multibrot_exponent_runtime.junit.xml",
      "test_nodeid": "tests/test_fractal_runtime_multibrot_exponent.py::test_multibrot_real_and_imaginary_exponent_controls_no_mouse"
    }
  ]
}
