    "tests/runtime_harness.py",
    "tests/test_fractal_runtime_sdf_realtime_pacing.py",
    "tests/test_fractal_runtime_resolution_pacing.py",
    "tests/test_fractal_runtime_runtime_walk_viewer.py",
    "artifacts"
  ],
  "required_operator_inputs": [
    "treat animation-driven parameter changes as pacing interactions",
    "prove animation itself triggers preview under measured slow/SDF load",
    "preserve manual control pacing behavior and full-quality settle",
    "keep the animation system simple and avoid a redesign"
  ],
  "forbidden_operator_prompts": [
    "redesign the animation UI in this slice",
    "add new animation targets in this slice",
    "implement GPU Color Pipeline postprocess in this slice",
    "implement per-source or per-row SDF downsample in this slice",
    "change SDF source semantics, capture/replay, or Color Pipeline UI behavior",
    "use physical mouse automation",
    "downgrade capture-quality or full-quality settle rendering"
  ],
  "required_defaults": {
    "slice_kind": "runtime_visible_animation_pacing_repair",
    "physical_mouse_automation": false,
    "runtime_publish_required": true,
    "published_runtime_proof_required": true,
    "capture_quality_downgraded": false,
    "animation_ui_redesign": false
  },
  "forbidden_defaults": {
    "gpu_postprocess": "deferred",
    "per_source_downsample": "deferred",
    "animation_ui_redesign": "forbidden",
    "new_animation_targets": "forbidden",
    "physical_mouse_automation": "forbidden"
  },
  "required_validation_commands": [
    "py -3.14 tools/viewer_host_run_logged_command.py --label animation_pacing_native --log artifacts/logs/animation_pacing_native.log --out-json artifacts/validation/animation_pacing_native.json --heartbeat-seconds 30 --timeout-seconds 600 -- ui_app/build_tests_vsdevcmd.cmd test_viewer_render_pacing",
    "py -3.14 tools/viewer_host_run_logged_command.py --label animation_pacing_runtime_publish --log artifacts/logs/animation_pacing_runtime_publish.log --out-json artifacts/validation/animation_pacing_runtime_publish.json --heartbeat-seconds 30 --timeout-seconds 600 -- ui_app/build_vsdevcmd.cmd",
    "py -3.14 tools/viewer_host_run_logged_command.py --label animation_pacing_runtime_sdf --log artifacts/logs/animation_pacing_runtime_sdf.log --out-json artifacts/validation/animation_pacing_runtime_sdf.json --heartbeat-seconds 30 --timeout-seconds 1200 -- py -3.14 tools/viewer_host_runtime_pytest_lane.py tests/test_fractal_runtime_sdf_realtime_pacing.py",
    "py -3.14 tools/viewer_host_run_logged_command.py --label animation_pacing_runtime_resolution --log artifacts/logs/animation_pacing_runtime_resolution.log --out-json artifacts/validation/animation_pacing_runtime_resolution.json --heartbeat-seconds 30 --timeout-seconds 1200 -- py -3.14 tools/viewer_host_runtime_pytest_lane.py tests/test_fractal_runtime_resolution_pacing.py",
    "py -3.14 tools/viewer_host_validate_slice_contract.py --contract docs/contracts/animation_pacing_integration.contract.json --out-json artifacts/validation/animation_pacing_contract.json",
    "py -3.14 tools/viewer_host_assert_phased_plan_sync.py",
    "py -3.14 tools/viewer_host_validate_hostile_audit.py --plan docs/notes/animation_pacing_integration_PHASED_PLAN.md --out-json artifacts/validation/animation_pacing_hostile_audit.json",
    "py -3.14 tools/code_quality_audit.py --check-baseline --out artifacts/validation/animation_pacing_code_quality.json",
    "py -3.14 tools/viewer_host_run_logged_command.py --label animation_pacing_diff_check --log artifacts/logs/animation_pacing_diff_check.log --out-json artifacts/validation/animation_pacing_diff_check.json --heartbeat-seconds 30 --timeout-seconds 120 -- git diff --check"
  ],
  "required_acceptance_assertions": [
    {
      "assertion_id": "contract_schema_valid",
