{
  "version": 1,
  "contract_id": "animation_pacing_integration",
  "feature_id": "sdf_performance_design",
  "workflow_type": "viewer_first",
  "plan_path": "docs/notes/animation_pacing_integration_PHASED_PLAN.md",
  "allowed_mutation_scope": [
    "docs/notes/animation_pacing_integration_PHASED_PLAN.md",
    "docs/contracts/animation_pacing_integration.contract.json",
    "HANDOFF_LOG.md",
    "ui_app/src/main.cpp",
    "ui_app/src/viewer_render_pacing.h",
    "ui_app/src/viewer_render_pacing.cpp",
