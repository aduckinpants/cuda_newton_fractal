    "py -3.14 tools/viewer_host_run_logged_command.py --label sdf_adaptive_pacing_runtime_publish --log artifacts/logs/sdf_adaptive_pacing_runtime_publish.log --out-json artifacts/validation/sdf_adaptive_pacing_runtime_publish.json --heartbeat-seconds 30 --timeout-seconds 600 -- ui_app/build_vsdevcmd.cmd",
    "py -3.14 tools/viewer_host_run_logged_command.py --label sdf_adaptive_pacing_runtime_sdf --log artifacts/logs/sdf_adaptive_pacing_runtime_sdf.log --out-json artifacts/validation/sdf_adaptive_pacing_runtime_sdf.json --heartbeat-seconds 30 --timeout-seconds 1200 -- py -3.14 tools/viewer_host_runtime_pytest_lane.py tests/test_fractal_runtime_sdf_realtime_pacing.py",
    "py -3.14 tools/viewer_host_run_logged_command.py --label sdf_adaptive_pacing_runtime_resolution --log artifacts/logs/sdf_adaptive_pacing_runtime_resolution.log --out-json artifacts/validation/sdf_adaptive_pacing_runtime_resolution.json --heartbeat-seconds 30 --timeout-seconds 1200 -- py -3.14 tools/viewer_host_runtime_pytest_lane.py tests/test_fractal_runtime_resolution_pacing.py",
    "py -3.14 tools/viewer_host_validate_slice_contract.py --contract docs/contracts/sdf_adaptive_preview_pacing.contract.json --out-json artifacts/validation/sdf_adaptive_pacing_contract.json",
