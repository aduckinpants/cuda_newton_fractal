  "required_operator_inputs": [
    "measure persistent no-mouse interaction preview and settle timing before claiming responsiveness",
    "make preview minimum scale adaptive from measured visible-frame cost instead of tuning blindly",
    "preserve fast/no-loss full-quality interaction behavior",
    "preserve severe SDF interaction preview recovery and one full-quality settle render"
  ],
  "forbidden_operator_prompts": [
    "implement GPU Color Pipeline postprocess in this slice",
    "implement per-source or per-row SDF downsample in this slice",
    "change visible Color Pipeline UI behavior",
    "change SDF source semantics, gates, phase behavior, capture/replay, or shared Lens downsample authority",
    "use physical mouse automation",
    "downgrade capture-quality or full-quality settle rendering",
    "claim the whole FPS problem is solved from helper-only proof"
