  "required_defaults": {
    "slice_kind": "runtime_visible_adaptive_pacing",
    "physical_mouse_automation": false,
    "runtime_publish_required": true,
    "published_runtime_proof_required": true,
    "capture_quality_downgraded": false,
    "full_quality_settle_preserved": true
  },
  "forbidden_defaults": {
    "gpu_postprocess": "deferred",
    "per_source_downsample": "deferred",
    "sdf_native_lanes": "deferred",
    "authored_sdf_pack_ui": "deferred",
    "visible_color_pipeline_ui_change": "forbidden",
    "physical_mouse_automation": "forbidden"
  },
  "required_validation_commands": [
