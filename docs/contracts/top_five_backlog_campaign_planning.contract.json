  "required_acceptance_assertions": [
    {
      "assertion_id": "contract_schema_valid",
      "description": "The top-five backlog campaign planning contract validates successfully",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/top_five_backlog_campaign_contract.json",
      "json_path": "checks.contract_schema_valid",
