    {
      "assertion_id": "hostile_audit_ok",
      "description": "The top-five backlog campaign planning hostile audit is complete",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/top_five_backlog_campaign_hostile_audit.json",
