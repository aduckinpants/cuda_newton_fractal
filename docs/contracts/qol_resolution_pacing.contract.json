{
  "version": 1,
  "contract_id": "qol_resolution_pacing",
  "feature_id": "qol_resolution_pacing_v1",
  "workflow_type": "viewer_first",
  "plan_path": "docs/notes/qol_resolution_pacing_PHASED_PLAN.md",
  "allowed_mutation_scope": [
    "docs/contracts",
    "docs/notes",
    "ui/fractal_binding_surface_v1.ui_schema.json",
    "ui/fractal_binding_surface_v1.binding_map.md",
    "ui/FractalBindingSurfaceV1.md",
    "ui_app/src/schema_binding.cpp",
    "ui_app/src/schema_binding.h",
    "ui_app/src/explaino_sidecar_controller.cpp",
    "ui_app/src/explaino_sidecar_measurement.cpp",
    "ui_app/src/safe_mode_schema.cpp",
    "ui_app/src/viewer_render_pacing.cpp",
    "ui_app/src/viewer_render_pacing.h",
    "ui_app/tests",
    "tests",
    "HANDOFF_LOG.md"
  ],
  "required_operator_inputs": [
    "aspect preset combo: Custom, 1:1, 4:3, 16:9, 16:10, 21:9",
    "one long-edge slider range [256,4096] step 16",
    "default derived UI is 4:3 with long edge 2048 preserving 2048x1536",
    "RenderSettings.resolution.x/y remain the runtime and persistence authority",
    "no physical mouse automation"
  ],
  "forbidden_operator_prompts": [
    "add a second persisted resolution source of truth",
    "remove CLI width/height compatibility",
    "change capture-quality or finding capture resolution authority",
    "reopen Multibrot exponent work in Branch 2",
    "use physical mouse automation"
  ],
  "required_defaults": {
    "branch": "codex/qol-resolution-pacing",
    "target_branch": "master",
    "aspect_default": "4:3",
    "long_edge_default": 2048,
    "resolution_authority": "RenderSettings.resolution.x/y",
    "no_physical_mouse_tests": true
  },
  "forbidden_defaults": {
    "persisted_aspect_field": "forbidden",
    "persisted_long_edge_field": "forbidden",
    "physical_mouse_tests": "forbidden"
  },
  "required_validation_commands": [
    "py -3.14 tools/code_quality_audit.py --check-baseline --out artifacts/logs/qol_resolution_pacing_code_quality.json",
    "py -3.14 tools/viewer_host_validate_slice_contract.py --contract docs/contracts/qol_resolution_pacing.contract.json --out-json artifacts/validation/qol_resolution_pacing_contract.json",
    "py -3.14 tools/viewer_host_assert_phased_plan_sync.py",
    "py -3.14 tools/viewer_host_validate_hostile_audit.py --plan docs/notes/qol_resolution_pacing_PHASED_PLAN.md --out-json artifacts/validation/qol_resolution_pacing_hostile_audit.json",
    "py -3.14 tools/viewer_host_run_logged_command.py --label qol_resolution_pacing_native_final --log artifacts/logs/qol_resolution_pacing_native_final.log -- ui_app/build_tests_vsdevcmd.cmd",
    "py -3.14 tools/viewer_host_run_logged_command.py --label qol_resolution_pacing_runtime_publish_final --log artifacts/logs/qol_resolution_pacing_runtime_publish_final.log -- ui_app/build_vsdevcmd.cmd",
    "py -3.14 -m pytest tests/test_fractal_runtime_resolution_pacing.py -q --junitxml artifacts/pytest/qol_resolution_pacing_runtime.junit.xml"
  ],
  "required_acceptance_assertions": [
    {
      "assertion_id": "qol_resolution_pacing_contract_schema_valid",
      "description": "The resolution/pacing contract validates successfully",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/qol_resolution_pacing_contract.json",
      "json_path": "checks.contract_schema_valid",
      "equals": true
    },
    {
      "assertion_id": "qol_resolution_pacing_plan_sync_ok",
      "description": "The phased plan stays synchronized",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/viewer_host_assert_phased_plan_sync.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "qol_resolution_pacing_hostile_audit_ok",
      "description": "The hostile audit is complete before closure",
      "evidence_kind": "validator_json",
      "artifact_path": "artifacts/validation/qol_resolution_pacing_hostile_audit.json",
      "json_path": "ok",
      "equals": true
    },
    {
      "assertion_id": "qol_resolution_pacing_runtime_no_mouse",
      "description": "Published viewer proof edits resolution controls without physical mouse automation",
      "evidence_kind": "runtime_junit_case",
      "artifact_path": "artifacts/pytest/qol_resolution_pacing_runtime.junit.xml",
      "test_nodeid": "tests/test_fractal_runtime_resolution_pacing.py::test_resolution_aspect_and_long_edge_controls_no_mouse"
    }
  ]
}
