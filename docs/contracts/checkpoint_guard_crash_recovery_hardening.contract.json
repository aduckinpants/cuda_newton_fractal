  "required_operator_inputs": [
    "preserve fail-closed workflow policy while replacing the crash dead-end with an explicit recovery lane",
    "add a repo-local recovery helper for dirty repo plus missing session baseline after a crash or rollback",
    "require explicit operator adoption before a stranded dirty snapshot can resume in a fresh session",
    "leave durable repo-local documentation that explains diagnosis, recovery, and the portable pattern for similar repos",
    "allow a clean-side checkpoint commit to scope itself to recovery files only when unrelated dirty carryover is still present"
  ],
  "forbidden_operator_prompts": [
    "add a broad ignore-hooks or bypass-recovery switch",
    "auto-adopt dirty crash state without explicit operator action",
    "treat a crash-resumed dirty session as a fresh clean session",
    "weaken PreToolUse, PostToolUse, or Stop fail-closed behavior"
  ],
  "required_defaults": {
    "recovery_reports_are_durable": "required",
    "dirty_state_adoption_is_explicit": "required",
    "stale_recovery_adoption_blocks_resume": "required",
    "workflow_docs_explain_crash_safe_resume": "required",
    "checkpoint_wrapper_can_scope_commit_paths": "required"
  },
  "forbidden_defaults": {
    "warning_only_crash_recovery": "forbidden",
    "silent_dirty_resume": "forbidden",
    "indefinite_reuse_of_recovery_adoption": "forbidden",
    "checkpoint_wrapper_stages_unrelated_dirty_paths": "forbidden"
  },
  "required_validation_commands": [
