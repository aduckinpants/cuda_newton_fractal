{
  "request_version": 1,
  "request_id": "fractal-sequence-grid-seed-drift-zip",
  "function_id": "fractal.sample",
  "mode": "sequence_grid",
  "overrides": [
    {"path": "fractal.view.fractal_type", "value": "explaino_rational_escape"},
    {"path": "fractal.params.explaino_warp_strength", "value": 0.35}
  ],
  "region": {
    "center_x": 0.0,
    "center_y": 0.0,
    "span_x": 0.2,
    "span_y": 0.2,
    "grid_width": 16,
    "grid_height": 16
  },
  "sequence": {
    "zip_paths": true,
    "vary": [
      {
        "path": "fractal.params.explaino_seed",
        "values": [4.0, 5.0, 6.0]
      },
      {
        "path": "fractal.view.explaino_seed_drift",
        "values": [0.1, 0.2, 0.3]
      }
    ]
  },
  "metrics": [
    "iterations",
    "status",
    "summary_mean_iterations",
    "summary_best_sequence_index"
  ]
}