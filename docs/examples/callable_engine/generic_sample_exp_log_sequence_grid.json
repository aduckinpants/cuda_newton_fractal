{
  "request_version": 1,
  "request_id": "generic-exp-log-sequence-grid",
  "function_id": "generic.sample",
  "mode": "sequence_grid",
  "function": {
    "expression": "compose(exp(z), scale * log(z + shift))",
    "params": {
      "scale_real": 1.0,
      "scale_imag": 0.0,
      "shift_real": 0.35,
      "shift_imag": 0.0
    }
  },
  "region": {
    "center_x": 0.0,
    "center_y": 0.0,
    "span_x": 4.0,
    "span_y": 4.0,
    "grid_width": 192,
    "grid_height": 192
  },
  "sequence": {
    "zip_paths": false,
    "vary": [
      {
        "path": "function.params.scale_real",
        "values": [0.5, 1.0, 1.5]
      }
    ]
  },
  "metrics": [
    "status",
    "value",
    "abs2"
  ]
}