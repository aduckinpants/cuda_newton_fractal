            {
              "op": "mul",
              "args": [
                {"op": "const", "value": 3.0},
                {"op": "pow_int", "base": {"op": "var_z"}, "exponent": 2}
              ]
            }
          ]
        }
      ]
    }
  },
  "params": {
    "steps": 48.0
  },
  "controls": [
    {"id": "steps", "param": "steps", "label": "Steps", "min": 1.0, "max": 200.0, "step": 1.0, "default": 48.0}
