{
  "schema_version": "1",
  "namespace": "fractal",
  "panels": [
    {
      "id": "view",
      "label": "View",
      "order": 10,
      "controls": [
        {
          "id": "fractal_type",
          "type": "combo",
          "label": "Fractal Type",
          "value_type": "enum",
          "order": 1,
          "default": "newton",
          "options": [
            { "id": "newton", "label": "Newton" },
            { "id": "nova", "label": "Nova" },
            { "id": "mandelbrot", "label": "Mandelbrot" },
            { "id": "julia", "label": "Julia" },
            { "id": "burning_ship", "label": "Burning Ship" },
            { "id": "multibrot", "label": "Multibrot" },
            { "id": "phoenix", "label": "Phoenix" },
            { "id": "explaino", "label": "Explaino" },
            { "id": "explaino_y", "label": "Explaino Y" },
            { "id": "explaino_fp", "label": "Explaino FP" },
            { "id": "explaino_nova", "label": "Explaino Nova" },
            { "id": "explaino_halley", "label": "Explaino Halley" },
            { "id": "explaino_dual", "label": "Explaino DualSeed" },
            { "id": "explaino_mult", "label": "Explaino Multiplicity" },
            { "id": "explaino_phoenix", "label": "Explaino Phoenix" },
            { "id": "explaino_transcendental", "label": "Explaino Transcendental" },
            { "id": "explaino_inertial", "label": "Explaino Inertial" },
            { "id": "explaino_julia", "label": "Explaino Julia" },
            { "id": "explaino_rational", "label": "Explaino Rational" },
            { "id": "multicorn", "label": "Multicorn" },
            { "id": "halley", "label": "Halley" },
            { "id": "collatz", "label": "Collatz" },
            { "id": "explaino_collatz", "label": "Explaino Collatz" },
            { "id": "mcmullen", "label": "McMullen" }
          ],
          "binding": { "kind": "param", "path": "fractal.view.fractal_type" },
          "help": "Select the fractal formula. View mapping/camera behavior remain the same across types."
        },
        {
          "id": "center_x",
          "type": "drag_float",
          "label": "Center X",
          "value_type": "float",
          "min": -2.0, "max": 2.0, "step": 0.001, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.view.center.x" }
        },
        {
          "id": "center_y",
          "type": "drag_float",
          "label": "Center Y",
          "value_type": "float",
          "min": -2.0, "max": 2.0, "step": 0.001, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.view.center.y" }
        },
        {
          "id": "zoom",
          "type": "drag_float",
          "label": "Zoom",
          "value_type": "float",
          "min": 1e-12, "max": 1000000000000.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.view.zoom" }
        },
        {
          "id": "rotation_deg",
          "type": "drag_float",
          "label": "Rotation (deg)",
          "help": "Optional: engine may ignore",
          "value_type": "float",
          "min": -180.0, "max": 180.0, "step": 0.1, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.view.rotation" }
        },
        {
          "id": "camera_behavior",
          "type": "combo",
          "label": "Camera Behavior",
          "value_type": "enum",
          "default": "complexity",
          "options": [
            { "id": "manual", "label": "Manual Pan" },
            { "id": "complexity", "label": "Complexity Gradient" },
            { "id": "orbit", "label": "Orbit Attractor" },
            { "id": "entropy", "label": "Entropy Seeker" },
            { "id": "off", "label": "Off" }
          ],
          "binding": { "kind": "param", "path": "fractal.view.camera_behavior" }
        },
        {
          "id": "auto_dive",
          "type": "checkbox",
          "label": "Auto-Dive",
          "value_type": "bool",
          "default": false,
          "binding": { "kind": "param", "path": "fractal.view.auto_dive" }
        },
        {
          "id": "dive_speed",
          "type": "slider_float",
          "label": "Dive Speed",
          "value_type": "float",
          "min": 0.0, "max": 5.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.view.dive_speed" },
          "visible_if": { "op": "eq", "path": "fractal.view.auto_dive", "value": true }
        },
        {
          "id": "auto_refresh",
          "type": "checkbox",
          "label": "Auto-refresh",
          "value_type": "bool",
          "default": true,
          "binding": { "kind": "param", "path": "fractal.view.auto_refresh" }
        },
        {
          "id": "render_once",
          "type": "button",
          "label": "Render Once",
          "binding": { "kind": "action", "path": "fractal.actions.render_once" }
        },
        {
          "id": "reset_view",
          "type": "button",
          "label": "Reset View",
          "binding": { "kind": "action", "path": "fractal.actions.reset_view" }
        },
        {
          "id": "reset_all",
          "type": "button",
          "label": "Reset All",
          "order": 901,
          "binding": { "kind": "action", "path": "fractal.actions.reset_all" }
        },
        {
          "id": "load_state",
          "type": "button",
          "label": "Load Finding State",
          "order": 902,
          "binding": { "kind": "action", "path": "fractal.actions.load_state" }
        },
        {
          "id": "capture_finding",
          "type": "button",
          "label": "Capture Finding",
          "order": 903,
          "binding": { "kind": "action", "path": "fractal.actions.capture_finding" }
        },
        {
          "id": "auto_increment_seed",
          "type": "checkbox",
          "label": "Auto-Increment Seed",
          "value_type": "bool",
          "default": false,
          "binding": { "kind": "param", "path": "fractal.view.auto_increment_seed" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          },
          "help": "Continuously advances the combined Explaino seed through the existing drift+tween seam."
        },
        {
          "id": "explaino_seed_rate",
          "type": "slider_float",
          "label": "Seed Increment Rate",
          "value_type": "float",
          "min": 0.001, "max": 5.0, "step": 0.001, "default": 0.05,
          "logarithmic": true,
          "binding": { "kind": "param", "path": "fractal.view.explaino_seed_rate" },
          "visible_if": { "op": "eq", "path": "fractal.view.auto_increment_seed", "value": true },
          "help": "Per-second rate for smooth Explaino seed stepping. Logarithmic scale gives more room in the low end. Left/Right arrow keys also scrub with acceleration."
        },
        {
          "id": "multibrot_power",
          "type": "slider_int",
          "label": "Multibrot Power",
          "value_type": "int",
          "min": 2, "max": 8, "step": 1, "default": 3,
          "binding": { "kind": "param", "path": "fractal.params.multibrot_power" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "multibrot,multicorn" },
          "help": "Exponent p in z_{n+1} = z_n^p + c (used only when Fractal Type = Multibrot)."
        },
        {
          "id": "mcmullen_preset",
          "type": "combo",
          "label": "McMullen Preset",
          "value_type": "enum",
          "default": "z3_z3",
          "options": [
            { "id": "z3_z3", "label": "z\u00b3 + \u03bb/z\u00b3" },
            { "id": "z2_z2", "label": "z\u00b2 + \u03bb/z\u00b2" },
            { "id": "z4_z2", "label": "z\u2074 + \u03bb/z\u00b2" },
            { "id": "z3_z2", "label": "z\u00b3 + \u03bb/z\u00b2" }
          ],
          "binding": { "kind": "param", "path": "fractal.params.mcmullen_preset" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "mcmullen" },
          "help": "Select the (m, n, lambda) preset for the McMullen rational map z^m + lambda/z^n."
        }
      ]
    },
    {
      "id": "lens",
      "label": "Lens",
      "order": 15,
      "controls": [
        {
          "id": "lens_enabled",
          "type": "checkbox",
          "label": "Lens Enabled",
          "value_type": "bool",
          "default": false,
          "binding": { "kind": "param", "path": "fractal.lens.enabled" }
        },
        {
          "id": "lens_downsample",
          "type": "combo",
          "label": "Lens Downsample",
          "value_type": "int",
          "default": "2",
          "options": [
            { "id": "1", "label": "1x (Full)" },
            { "id": "2", "label": "2x" },
            { "id": "4", "label": "4x" },
            { "id": "8", "label": "8x" },
            { "id": "16", "label": "16x" }
          ],
          "binding": { "kind": "param", "path": "fractal.lens.downsample" },
          "visible_if": { "op": "eq", "path": "fractal.lens.enabled", "value": true }
        }
      ]
    },
    {
      "id": "fractal",
      "label": "Fractal",
      "order": 20,
      "controls": [
        {
          "id": "max_iter",
          "type": "slider_int",
          "label": "Max Iterations",
          "value_type": "int",
          "min": 1, "max": 5000, "step": 1, "default": 500,
          "binding": { "kind": "param", "path": "fractal.params.max_iter" }
        },
        {
          "id": "auto_max_iter",
          "type": "checkbox",
          "label": "Auto Max Iterations",
          "help": "Scale iterations with zoom depth and fractal type",
          "value_type": "bool",
          "default": false,
          "binding": { "kind": "param", "path": "fractal.view.auto_max_iter" }
        },
        {
          "id": "epsilon",
          "type": "drag_float",
          "label": "Epsilon",
          "help": "Convergence threshold",
          "value_type": "float",
          "min": 1e-12, "max": 0.01, "step": 1e-06, "default": 1e-06,
          "binding": { "kind": "param", "path": "fractal.params.epsilon" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz,halley"
          }
        },
        {
          "id": "nova_alpha",
          "type": "slider_float",
          "label": "Nova Alpha",
          "help": "Relaxation factor in z_{n+1} = z_n - a f(z)/f'(z) + c",
          "value_type": "float",
          "min": 0.0, "max": 5.0, "step": 0.01, "default": 0.5,
          "binding": { "kind": "param", "path": "fractal.params.nova_alpha" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "nova,explaino_nova"
          }
        },
        {
          "id": "phoenix_p_real",
          "type": "drag_float",
          "label": "Phoenix p (real)",
          "help": "Memory term p in z_{n+1} = z_n^2 + c + p z_{n-1}",
          "value_type": "float",
          "min": -1.0, "max": 1.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.phoenix_p_real" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "phoenix,explaino_phoenix"
          }
        },
        {
          "id": "phoenix_p_imag",
          "type": "drag_float",
          "label": "Phoenix p (imag)",
          "value_type": "float",
          "min": -1.0, "max": 1.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.phoenix_p_imag" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "phoenix,explaino_phoenix"
          }
        },
        {
          "id": "transcendental_func",
          "type": "combo",
          "label": "Transcendental Function",
          "value_type": "enum",
          "default": "f_sin",
          "options": [
            { "id": "f_sin", "label": "sin(z)" },
            { "id": "f_exp_minus_1", "label": "exp(z) - 1" },
            { "id": "f_cosh", "label": "cosh(z)" }
          ],
          "binding": { "kind": "param", "path": "fractal.params.transcendental_func" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "explaino_transcendental" },
          "help": "Select which transcendental function to apply Newton's method to."
        },
        {
          "id": "poly_kind",
          "type": "combo",
          "label": "Polynomial",
          "value_type": "enum",
          "default": "z3_minus_1",
          "options": [
            { "id": "z3_minus_1", "label": "z^3 - 1" },
            { "id": "z4_minus_1", "label": "z^4 - 1" },
            { "id": "custom", "label": "Custom" }
          ],
          "binding": { "kind": "param", "path": "fractal.params.poly_kind" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,halley"
          }
        },
        {
          "id": "poly_c0",
          "type": "drag_float",
          "label": "Coeff c0 (z^0)",
          "value_type": "float",
          "min": -10.0, "max": 10.0, "step": 0.01, "default": -1.0,
          "binding": { "kind": "param", "path": "fractal.params.poly_coeffs.0" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,halley"
          }
        },
        {
          "id": "poly_c1",
          "type": "drag_float",
          "label": "Coeff c1 (z^1)",
          "value_type": "float",
          "min": -10.0, "max": 10.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.poly_coeffs.1" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,halley"
          }
        },
        {
          "id": "poly_c2",
          "type": "drag_float",
          "label": "Coeff c2 (z^2)",
          "value_type": "float",
          "min": -10.0, "max": 10.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.poly_coeffs.2" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,halley"
          }
        },
        {
          "id": "poly_c3",
          "type": "drag_float",
          "label": "Coeff c3 (z^3)",
          "value_type": "float",
          "min": -10.0, "max": 10.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.poly_coeffs.3" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,nova,halley"
          }
        },
        {
          "id": "poly_c4",
          "type": "drag_float",
          "label": "Coeff c4 (z^4)",
          "value_type": "float",
          "min": -10.0, "max": 10.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.poly_coeffs.4" },
          "visible_if": { "op": "in", "path": "fractal.view.fractal_type", "value": "newton,halley" }
        },
        {
          "id": "explaino_seed",
          "type": "slider_double",
          "label": "Explaino Seed",
          "value_type": "double",
          "min": 0.0, "max": 10.0, "step": 0.001, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.explaino_seed" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          },
          "help": "Primary Explaino seed control. The host splits this combined value into the integer seed base and fractional drift."
        },
        {
          "id": "explaino_seed_b",
          "type": "slider_double",
          "label": "Explaino Seed B",
          "value_type": "double",
          "min": 0.0, "max": 10.0, "step": 0.001, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.explaino_seed_b" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "explaino_dual" },
          "help": "Secondary Explaino seed for DualSeed root-pack blending."
        },
        {
          "id": "explaino_mix",
          "type": "slider_float",
          "label": "Explaino Mix",
          "value_type": "float",
          "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.5,
          "binding": { "kind": "param", "path": "fractal.params.explaino_mix" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "explaino_dual" },
          "help": "Blend between the primary Explaino seed surface and the secondary seed surface."
        },
        {
          "id": "prev_seed",
          "type": "button",
          "label": "Prev Seed",
          "binding": { "kind": "action", "path": "fractal.actions.prev_seed" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "next_seed",
          "type": "button",
          "label": "Next Seed",
          "binding": { "kind": "action", "path": "fractal.actions.next_seed" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_warp_strength",
          "type": "slider_float",
          "label": "Explaino Warp",
          "value_type": "float",
          "min": 0.0, "max": 5.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.explaino_warp_strength" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_root_spread",
          "type": "slider_float",
          "label": "Root Spread",
          "help": "Controls the radius of generated root placements, independent of warp distortion.",
          "value_type": "float",
          "min": 0.0, "max": 10.0, "step": 0.01, "default": 0.5,
          "binding": { "kind": "param", "path": "fractal.params.explaino_root_spread" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_phase_strength",
          "type": "slider_float",
          "label": "Phase Strength",
          "help": "Multiplier on phase modulation of root angles. Higher values make the Phase slider more influential.",
          "value_type": "float",
          "min": 0.0, "max": 20.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.view.explaino_phase_strength" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_damping",
          "type": "slider_float",
          "label": "Newton Damping",
          "help": "Multiplier on the Newton step size. Values <1 slow convergence for richer structure; >1 can overshoot.",
          "value_type": "float",
          "min": 0.01, "max": 10.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.explaino_damping" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_cluster_radius",
          "type": "slider_float",
          "label": "Cluster Radius",
          "help": "Distance between paired near-coincident roots. Smaller values produce near-degenerate polynomials that expose solver failure geometry.",
          "value_type": "float",
          "min": 0.0, "max": 5.0, "step": 0.001, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.explaino_cluster_radius" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "explaino_mult,explaino_rational" }
        },
        {
          "id": "momentum_beta",
          "type": "slider_float",
          "label": "Momentum Beta",
          "help": "Strength of previous-step momentum. Higher values carry more of the previous Newton step direction forward.",
          "value_type": "float",
          "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.params.momentum_beta" },
          "visible_if": { "op": "eq", "path": "fractal.view.fractal_type", "value": "explaino_inertial" }
        },
        {
          "id": "explaino_phase",
          "type": "slider_float",
          "label": "Explaino Phase",
          "value_type": "float",
          "min": -6.283185307179586, "max": 6.283185307179586, "step": 0.01, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.view.explaino_phase" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        },
        {
          "id": "explaino_seed_drift",
          "type": "slider_float",
          "label": "Explaino Seed Fraction",
          "value_type": "float",
          "min": 0.0, "max": 0.999, "step": 0.001, "default": 0.0,
          "binding": { "kind": "param", "path": "fractal.view.explaino_seed_drift" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          },
          "help": "Advanced fractional component of the combined Explaino seed. Usually edit Explaino Seed instead."
        },
        {
          "id": "explaino_seed_tween",
          "type": "checkbox",
          "label": "Explaino Seed Tween",
          "value_type": "bool",
          "default": true,
          "binding": { "kind": "param", "path": "fractal.view.explaino_seed_tween" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "explaino,explaino_y,explaino_fp,explaino_nova,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_julia,explaino_rational,explaino_collatz"
          }
        }
      ]
    },
    {
      "id": "color",
      "label": "Color",
      "order": 25,
      "controls": [
        {
          "id": "coloring_mode_newton",
          "type": "combo",
          "label": "Coloring Mode",
          "value_type": "enum",
          "order": 1,
          "default": "joy_basins",
          "options": [
            { "id": "root_basin", "label": "Root Basins (Root-Finding)" },
            { "id": "joy_basins", "label": "Joy Basins (All paths succeed)" },
            { "id": "iteration_count", "label": "Iteration Count" },
            { "id": "smooth_escape", "label": "Smooth Escape" }
          ],
          "binding": { "kind": "param", "path": "fractal.params.coloring_mode" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "newton,explaino,explaino_y,explaino_fp,explaino_halley,explaino_dual,explaino_mult,explaino_phoenix,explaino_transcendental,explaino_inertial,explaino_rational,explaino_collatz,halley"
          },
          "help": "Newton and the root-finding Explaino variants support basin-based coloring. 'Joy Basins' emphasizes warm success basins while keeping non-convergent regions as a subdued undertow."
        },
        {
          "id": "coloring_mode_escape",
          "type": "combo",
          "label": "Coloring Mode",
          "value_type": "enum",
          "order": 1,
          "default": "smooth_escape",
          "options": [
            { "id": "iteration_count", "label": "Iteration Count" },
            { "id": "smooth_escape", "label": "Smooth Escape" }
          ],
          "binding": { "kind": "param", "path": "fractal.params.coloring_mode" },
          "visible_if": {
            "op": "in",
            "path": "fractal.view.fractal_type",
            "value": "nova,explaino_nova,mandelbrot,julia,burning_ship,multibrot,phoenix,explaino_julia,multicorn,collatz,mcmullen"
          },
          "help": "Escape-time fractals use iteration-based coloring."
        },
        {
          "id": "exposure",
          "type": "slider_float",
          "label": "Exposure",
          "value_type": "float",
          "min": 0.1, "max": 5.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.exposure" }
        },
        {
          "id": "color_saturation",
          "type": "slider_float",
          "label": "Saturation",
          "value_type": "float",
          "min": 0.0, "max": 3.0, "step": 0.01, "default": 1.15,
          "binding": { "kind": "param", "path": "fractal.params.color_saturation" }
        },
        {
          "id": "color_contrast",
          "type": "slider_float",
          "label": "Contrast",
          "value_type": "float",
          "min": 0.0, "max": 3.0, "step": 0.01, "default": 1.1,
          "binding": { "kind": "param", "path": "fractal.params.color_contrast" }
        },
        {
          "id": "tint_r",
          "type": "slider_float",
          "label": "Tint Red",
          "value_type": "float",
          "min": 0.0, "max": 2.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.color_tint_r" }
        },
        {
          "id": "tint_g",
          "type": "slider_float",
          "label": "Tint Green",
          "value_type": "float",
          "min": 0.0, "max": 2.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.color_tint_g" }
        },
        {
          "id": "tint_b",
          "type": "slider_float",
          "label": "Tint Blue",
          "value_type": "float",
          "min": 0.0, "max": 2.0, "step": 0.01, "default": 1.0,
          "binding": { "kind": "param", "path": "fractal.params.color_tint_b" }
        }
      ]
    },
    {
      "id": "render",
      "label": "Render",
      "order": 30,
      "controls": [
        {
          "id": "width",
          "type": "slider_int",
          "label": "Width",
          "value_type": "int",
          "min": 64, "max": 4096, "step": 1, "default": 1024,
          "binding": { "kind": "param", "path": "fractal.render.resolution.x" }
        },
        {
          "id": "height",
          "type": "slider_int",
          "label": "Height",
          "value_type": "int",
          "min": 64, "max": 4096, "step": 1, "default": 768,
          "binding": { "kind": "param", "path": "fractal.render.resolution.y" }
        },
        {
          "id": "block_size",
          "type": "combo",
          "label": "Block Size",
          "value_type": "int",
          "default": "256",
          "options": [
            { "id": "64", "label": "64" },
            { "id": "128", "label": "128" },
            { "id": "256", "label": "256" },
            { "id": "512", "label": "512" }
          ],
          "binding": { "kind": "param", "path": "fractal.render.block_size" }
        },
        {
          "id": "device_id",
          "type": "slider_int",
          "label": "Device",
          "help": "Optional: engine clamps to available devices",
          "value_type": "int",
          "min": 0, "max": 7, "step": 1, "default": 0,
          "binding": { "kind": "param", "path": "fractal.render.device_id" }
        },
        {
          "id": "benchmark",
          "type": "checkbox",
          "label": "Benchmark mode",
          "value_type": "bool",
          "default": false,
          "binding": { "kind": "param", "path": "fractal.render.benchmark" }
        },
        {
          "id": "capture_diagnostic",
          "type": "button",
          "label": "Capture Diagnostic",
          "binding": { "kind": "action", "path": "fractal.actions.capture_diagnostic" }
        }
      ]
    }
  ]
}
