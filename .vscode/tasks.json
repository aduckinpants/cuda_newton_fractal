{
  "version": "2.0.0",
  "presentation": {
    "showReuseMessage": false,
    "close": true
  },
  "inputs": [
    {
      "id": "agentSliceIntent",
      "type": "promptString",
      "description": "Short intent for the pending work-slice HANDOFF_LOG breadcrumb",
      "default": "tighten the active slice"
    },
    {
      "id": "agentSliceProfile",
      "type": "pickString",
      "description": "Expected public validation profile for this slice",
      "options": [
        "native",
        "runtime",
        "catalog",
        "checkpoint",
        "unspecified"
      ],
      "default": "native"
    },
    {
      "id": "agentSlicePlan",
      "type": "promptString",
      "description": "Checked-in phased plan path for this slice",
      "default": "docs/notes/hard_denial_workflow_lock_and_fits_reclosure_PHASED_PLAN.md"
    },
    {
      "id": "agentSliceContract",
      "type": "promptString",
      "description": "Checked-in machine-readable contract path for this slice",
      "default": "docs/contracts/hard_denial_workflow_lock_and_fits_reclosure.contract.json"
    }
  ],
  "tasks": [
    {
      "label": "agent: session bootstrap",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_session_bootstrap.py",
        "--audit",
        "--tail-handoff",
        "8"
      ],
      "problemMatcher": []
    },
    {
      "label": "agent: begin work slice",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_begin_work_slice.py",
        "--intent",
        "${input:agentSliceIntent}",
        "--profile",
        "${input:agentSliceProfile}",
        "--plan",
        "${input:agentSlicePlan}",
        "--contract",
        "${input:agentSliceContract}"
      ],
      "problemMatcher": []
    },
    {
      "label": "agent: assert phased plan sync",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_assert_phased_plan_sync.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "verify: code quality audit",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/code_quality_audit.py",
        "--check-baseline",
        "--out",
        "artifacts/code_quality_report.json"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: native helper tests",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "native helper tests",
        "--log",
        "artifacts/verify_native_helper_tests.log",
        "--",
        "cmd",
        "/c",
        "ui_app\\build_tests_vsdevcmd.cmd"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: runtime publish",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "runtime publish",
        "--log",
        "artifacts/verify_runtime_publish.log",
        "--",
        "cmd",
        "/c",
        "ui_app\\build_vsdevcmd.cmd"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: runtime probe/session pytest",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "runtime probe session pytest",
        "--log",
        "artifacts/verify_runtime_probe_session_pytest.log",
        "--",
        "py",
        "-3.14",
        "tools/viewer_host_runtime_pytest_lane.py",
        "tests/test_fractal_runtime_batch_cli.py",
        "tests/test_fractal_runtime_probe_cli.py",
        "tests/test_fractal_runtime_session.py",
        "tests/test_function_descriptor_cli.py",
        "tests/test_generic_probe_cli.py"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: runtime artifact tools",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "runtime artifact tools",
        "--log",
        "artifacts/verify_runtime_artifact_tools.log",
        "--",
        "py",
        "-3.14",
        "tools/viewer_host_runtime_pytest_lane.py",
        "tests/test_explaino_runtime_walk_tool.py",
        "tests/test_flashlight_bridge_runner.py",
        "tests/test_fractal_runtime_flashlight_probe.py",
        "tests/test_fractal_runtime_flashlight_bridge.py",
        "tests/test_fractal_runtime_explaino_runtime_walk.py"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: runtime ui harness",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "runtime ui harness",
        "--log",
        "artifacts/verify_runtime_ui_harness.log",
        "--",
        "py",
        "-3.14",
        "tools/viewer_host_runtime_pytest_lane.py",
        "tests/test_fractal_runtime_explaino_dual.py",
        "tests/test_fractal_runtime_explaino_escape_variants.py",
        "tests/test_fractal_runtime_explaino_sidecar_live.py",
        "tests/test_fractal_runtime_shutdown.py",
        "tests/test_fractal_runtime_sweep_pause.py",
        "tests/test_fractal_runtime_runtime_walk_viewer.py",
        "-k",
        "not test_runtime_walk_viewer_tolerates_missing_companion_fits and not test_runtime_walk_viewer_can_boot_from_fits_only_cli"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: catalog smoke",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "catalog smoke",
        "--log",
        "artifacts/verify_catalog_smoke.log",
        "--",
        "py",
        "-3.14",
        "tools/reality_toolkit/scripts/run_fractal_catalog_smoke.py",
        "--strict",
        "--out-dir",
        "artifacts/fractal_catalog_smoke_profile"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: profile native",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "-c",
        "print('Run the dependent verification tasks (see dependsOn).')"
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "verify: code quality audit",
        "verify: native helper tests"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: runtime walk FITS witnesses",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "tools/viewer_host_run_logged_command.py",
        "--label",
        "runtime walk FITS witnesses",
        "--log",
        "artifacts/verify_runtime_walk_fits_witnesses.log",
        "--",
        "py",
        "-3.14",
        "tools/viewer_host_runtime_pytest_lane.py",
        "tests/test_fractal_runtime_runtime_walk_viewer.py",
        "-k",
        "test_runtime_walk_viewer_tolerates_missing_companion_fits or test_runtime_walk_viewer_can_boot_from_fits_only_cli"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: profile runtime",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "-c",
        "print('Run the dependent verification tasks (see dependsOn).')"
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "verify: code quality audit",
        "verify: runtime publish",
        "verify: runtime probe/session pytest",
        "verify: runtime artifact tools",
        "verify: runtime ui harness"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: profile catalog",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "-c",
        "print('Run the dependent verification tasks (see dependsOn).')"
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "verify: code quality audit",
        "verify: runtime publish",
        "verify: catalog smoke"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "verify: profile checkpoint",
      "type": "shell",
      "command": "py",
      "args": [
        "-3.14",
        "-c",
        "print('Run the dependent verification tasks (see dependsOn).')"
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "verify: code quality audit",
        "verify: native helper tests",
        "verify: runtime publish",
        "verify: runtime probe/session pytest",
        "verify: runtime artifact tools",
        "verify: runtime ui harness"
      ],
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
